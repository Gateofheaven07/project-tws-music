generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model untuk authentication
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  playlists   Playlist[]
  favorites   Favorite[]
  playHistory PlayHistory[]
  
  @@map("users")
}

// Playlist model
model Playlist {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  isPublic    Boolean  @default(false)
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  songs PlaylistSong[]

  @@index([userId])
  @@map("playlists")
}

// Junction table untuk Playlist dan Song
model PlaylistSong {
  id         String   @id @default(cuid())
  playlistId String
  songId     String
  addedAt    DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song     Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([playlistId, songId])
  @@index([playlistId])
  @@index([songId])
  @@map("playlist_songs")
}

// Song/Music model (cache dari Deezer/YouTube)
model Song {
  id          String   @id @default(cuid())
  title       String
  artist      String
  album       String?
  duration    Int      // dalam detik
  deezerUrl   String?  @unique
  youtubeUrl  String?  @unique
  thumbnail   String?
  genre       String?
  releaseDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  playlists PlaylistSong[]
  favorites Favorite[]
  playHistory PlayHistory[]

  @@index([title])
  @@index([artist])
  @@map("songs")
}

// Favorite model
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  songId    String
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song  @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([userId, songId])
  @@index([userId])
  @@index([songId])
  @@map("favorites")
}

// Play History model
model PlayHistory {
  id        String   @id @default(cuid())
  userId    String
  songId    String
  playedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([songId])
  @@map("play_history")
}
